        <mxCell id="GG1ei2N0N4fxY809Vq1g-39" parent="1" style="text;whiteSpace=wrap;html=1;" value="&lt;table&gt;&lt;thead&gt;&lt;tr&gt;&lt;th&gt;Point&lt;/th&gt;&lt;th&gt;Public Cloud&lt;/th&gt;&lt;th&gt;Private Cloud&lt;/th&gt;&lt;/tr&gt;&lt;/thead&gt;&lt;tbody&gt;&lt;tr&gt;&lt;td&gt;Used by&lt;/td&gt;&lt;td&gt;Many customers&lt;/td&gt;&lt;td&gt;One organization&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Example&lt;/td&gt;&lt;td&gt;AWS, Azure, GCP&lt;/td&gt;&lt;td&gt;VMware, OpenStack, Azure Stack&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Ownership&lt;/td&gt;&lt;td&gt;Cloud provider&lt;/td&gt;&lt;td&gt;Company or dedicated vendor&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Cost model&lt;/td&gt;&lt;td&gt;Pay-as-you-use&lt;/td&gt;&lt;td&gt;Higher fixed cost&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Control&lt;/td&gt;&lt;td&gt;Less infrastructure control&lt;/td&gt;&lt;td&gt;More control&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Security isolation&lt;/td&gt;&lt;td&gt;Logical isolation&lt;/td&gt;&lt;td&gt;Stronger dedicated isolation&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Best for&lt;/td&gt;&lt;td&gt;Fast scaling, startups, internet apps&lt;/td&gt;&lt;td&gt;Banks, healthcare, government, regulated systems&lt;/td&gt;&lt;/tr&gt;&lt;/tbody&gt;&lt;/table&gt;" vertex="1">
          <mxGeometry height="200" width="560" x="820" y="3820" as="geometry" />
        </mxCell>
        <mxCell id="GG1ei2N0N4fxY809Vq1g-40" parent="1" style="rounded=1;whiteSpace=wrap;html=1;" value="azure stack : Ms&#39;s hybrid / private cloud family that brigns azure like services into your own data center , branch , factory or any disconnected locations." vertex="1">
