        <mxCell id="_rzVe7CSYrXBFZ04XZDb-19" parent="1" style="whiteSpace=wrap;html=1;rounded=1;" value="&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; X X X X X&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; X&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp;X&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp;X&amp;nbsp; &amp;nbsp; O O O&amp;nbsp; &amp;nbsp; X&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp;X&amp;nbsp; &amp;nbsp; O O O&amp;nbsp; &amp;nbsp; X&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; X&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp;X&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; X X X X X&lt;/div&gt;" vertex="1">
