        <mxCell id="GG1ei2N0N4fxY809Vq1g-41" parent="1" style="text;whiteSpace=wrap;html=1;fontSize=14;" value="&lt;table&gt;&lt;thead&gt;&lt;tr&gt;&lt;th&gt;Need&lt;/th&gt;&lt;th&gt;Why Azure Stack helps&lt;/th&gt;&lt;/tr&gt;&lt;/thead&gt;&lt;tbody&gt;&lt;tr&gt;&lt;td&gt;Data must stay inside company/DC&lt;/td&gt;&lt;td&gt;Banking, government, defense, healthcare, telecom&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Low latency required&lt;/td&gt;&lt;td&gt;Factory, hospital, trading, telecom edge&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Internet may be unreliable&lt;/td&gt;&lt;td&gt;Remote plant, ship, mine, branch office&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Private cloud requirement&lt;/td&gt;&lt;td&gt;Apps run in company-owned data center&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Same Azure-like model wanted&lt;/td&gt;&lt;td&gt;Azure Portal, ARM templates, DevOps, policies&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Hybrid architecture&lt;/td&gt;&lt;td&gt;Some apps in Azure, some in DC&lt;/td&gt;&lt;/tr&gt;&lt;/tbody&gt;&lt;/table&gt;" vertex="1">
          <mxGeometry height="140" width="600" x="820" y="4250" as="geometry" />
        </mxCell>
