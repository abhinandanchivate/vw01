        <mxCell id="_rzVe7CSYrXBFZ04XZDb-2" parent="1" style="text;whiteSpace=wrap;html=1;fontSize=16;" value="&lt;h3 data-section-id=&quot;11l6du2&quot; data-start=&quot;2739&quot; data-end=&quot;2773&quot;&gt;Vehicle Service Recommendation&lt;/h3&gt;&lt;br&gt;&lt;p data-start=&quot;2775&quot; data-end=&quot;2829&quot;&gt;&lt;br&gt;&lt;/p&gt;&lt;p data-start=&quot;2831&quot; data-end=&quot;2865&quot;&gt;The prescriptive system evaluates:&lt;/p&gt;&lt;br&gt;&lt;ul data-start=&quot;2867&quot; data-end=&quot;2989&quot;&gt;&lt;br&gt;&lt;li data-section-id=&quot;6igfeb&quot; data-start=&quot;2867&quot; data-end=&quot;2881&quot;&gt;&lt;br&gt;Vehicle risk&lt;br&gt;&lt;/li&gt;&lt;br&gt;&lt;li data-section-id=&quot;oxzr0c&quot; data-start=&quot;2882&quot; data-end=&quot;2905&quot;&gt;&lt;br&gt;Workshop availability&lt;br&gt;&lt;/li&gt;&lt;br&gt;&lt;li data-section-id=&quot;9bitot&quot; data-start=&quot;2906&quot; data-end=&quot;2928&quot;&gt;&lt;br&gt;Spare-part inventory&lt;br&gt;&lt;/li&gt;&lt;br&gt;&lt;li data-section-id=&quot;1h27629&quot; data-start=&quot;2929&quot; data-end=&quot;2948&quot;&gt;&lt;br&gt;Customer location&lt;br&gt;&lt;/li&gt;&lt;br&gt;&lt;li data-section-id=&quot;1mxyi0u&quot; data-start=&quot;2949&quot; data-end=&quot;2963&quot;&gt;&lt;br&gt;Service cost&lt;br&gt;&lt;/li&gt;&lt;br&gt;&lt;li data-section-id=&quot;15vjzup&quot; data-start=&quot;2964&quot; data-end=&quot;2989&quot;&gt;&lt;br&gt;Technician availability&lt;br&gt;&lt;/li&gt;&lt;br&gt;&lt;/ul&gt;&lt;br&gt;&lt;h3 data-section-id=&quot;329tgr&quot; data-start=&quot;2991&quot; data-end=&quot;3014&quot;&gt;&lt;/h3&gt;" vertex="1">
          <mxGeometry height="620" width="360" x="160" y="2390" as="geometry" />
