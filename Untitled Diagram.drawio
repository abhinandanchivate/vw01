        <mxCell id="5tKftZWC_2B9X48VGRJW-2" parent="1" style="whiteSpace=wrap;html=1;rounded=1;" value="Predictions :&amp;nbsp;&lt;div&gt;1. correctly predicted as possitive&lt;/div&gt;&lt;div&gt;2. correctly predicted as negative&amp;nbsp;&lt;/div&gt;&lt;div&gt;3. incorrectly predicted as possitive&lt;/div&gt;&lt;div&gt;incorrectly predicted as negative&lt;/div&gt;" vertex="1">
