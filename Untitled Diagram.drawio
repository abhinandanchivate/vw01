        <mxCell id="5tKftZWC_2B9X48VGRJW-12" parent="1" style="whiteSpace=wrap;html=1;rounded=1;" value="scalarstnd" vertex="1">
          <mxGeometry height="60" width="120" x="590" y="6540" as="geometry" />
        </mxCell>
        <mxCell id="5tKftZWC_2B9X48VGRJW-17" edge="1" parent="1" source="5tKftZWC_2B9X48VGRJW-14" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" target="5tKftZWC_2B9X48VGRJW-16" value="">
          <mxGeometry relative="1" as="geometry" />
