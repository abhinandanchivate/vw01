        </mxCell>
        <mxCell id="5tKftZWC_2B9X48VGRJW-16" parent="1" style="whiteSpace=wrap;html=1;rounded=1;" value="Failure / No Failure prediction" vertex="1">
          <mxGeometry height="60" width="120" x="590" y="6820" as="geometry" />
        </mxCell>
        <mxCell id="5tKftZWC_2B9X48VGRJW-21" edge="1" parent="1" source="5tKftZWC_2B9X48VGRJW-18" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" target="5tKftZWC_2B9X48VGRJW-20" value="">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="5tKftZWC_2B9X48VGRJW-18" parent="1" style="whiteSpace=wrap;html=1;rounded=1;" value="&lt;table&gt;&lt;thead&gt;&lt;tr&gt;&lt;th&gt;Feature&lt;/th&gt;&lt;th align=&quot;right&quot;&gt;Example value&lt;/th&gt;&lt;/tr&gt;&lt;/thead&gt;&lt;tbody&gt;&lt;tr&gt;&lt;td&gt;Mileage&lt;/td&gt;&lt;td align=&quot;right&quot;&gt;75,000&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Engine alerts&lt;/td&gt;&lt;td align=&quot;right&quot;&gt;5&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Service gap&lt;/td&gt;&lt;td align=&quot;right&quot;&gt;12&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Brake wear&lt;/td&gt;&lt;td align=&quot;right&quot;&gt;80&lt;/td&gt;&lt;/tr&gt;&lt;/tbody&gt;&lt;/table&gt;" vertex="1">
          <mxGeometry height="130" width="300" x="790" y="6540" as="geometry" />
        </mxCell>
        <mxCell id="5tKftZWC_2B9X48VGRJW-20" parent="1" style="whiteSpace=wrap;html=1;rounded=1;" value="&lt;table&gt;&lt;thead&gt;&lt;tr&gt;&lt;th&gt;Feature&lt;/th&gt;&lt;th align=&quot;right&quot;&gt;Original value&lt;/th&gt;&lt;th align=&quot;right&quot;&gt;Scaled value&lt;/th&gt;&lt;/tr&gt;&lt;/thead&gt;&lt;tbody&gt;&lt;tr&gt;&lt;td&gt;Mileage&lt;/td&gt;&lt;td align=&quot;right&quot;&gt;75,000&lt;/td&gt;&lt;td align=&quot;right&quot;&gt;1.2&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Engine alerts&lt;/td&gt;&lt;td align=&quot;right&quot;&gt;5&lt;/td&gt;&lt;td align=&quot;right&quot;&gt;1.1&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Service gap&lt;/td&gt;&lt;td align=&quot;right&quot;&gt;12&lt;/td&gt;&lt;td align=&quot;right&quot;&gt;0.8&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Brake wear&lt;/td&gt;&lt;td align=&quot;right&quot;&gt;80&lt;/td&gt;&lt;td align=&quot;right&quot;&gt;1.4&lt;/td&gt;&lt;/tr&gt;&lt;/tbody&gt;&lt;/table&gt;" vertex="1">
          <mxGeometry height="105" width="270" x="1260" y="6552.5" as="geometry" />
        </mxCell>
        <mxCell id="5tKftZWC_2B9X48VGRJW-22" parent="1" style="text;whiteSpace=wrap;html=1;" value="&lt;p&gt;The scaled value is calculated using the &lt;strong&gt;StandardScaler formula&lt;/strong&gt;:&lt;/p&gt;&lt;p&gt;genui{&quot;math_block_widget_always_prefetch_v2&quot;:{&quot;content&quot;:&quot;z=\frac{x-\mu}{\sigma}&quot;}}&lt;/p&gt;&lt;p&gt;Where:&lt;/p&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;(x) = original value&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;(\mu) = mean of that feature in the training dataset&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;(\sigma) = standard deviation of that feature&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;(z) = scaled value&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;p&gt;The scaled values &lt;code&gt;1.2&lt;/code&gt;, &lt;code&gt;1.1&lt;/code&gt;, &lt;code&gt;0.8&lt;/code&gt;, and &lt;code&gt;1.4&lt;/code&gt; were illustrative. To calculate them exactly, we need the mean and standard deviation of each column.&lt;/p&gt;&lt;h2&gt;Example: Mileage&lt;/h2&gt;&lt;p&gt;Suppose the training dataset has:&lt;/p&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;Mean mileage = &lt;code&gt;51,000&lt;/code&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Standard deviation = &lt;code&gt;20,000&lt;/code&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Vehicle mileage = &lt;code&gt;75,000&lt;/code&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;h1&gt;[&lt;br&gt;\text{Scaled mileage}&lt;/h1&gt;&lt;h1&gt;\frac{75000-51000}{20000}&lt;/h1&gt;&lt;h1&gt;\frac{24000}{20000}&lt;/h1&gt;&lt;p&gt;1.2&lt;br&gt;]&lt;/p&gt;&lt;p&gt;Therefore:&lt;/p&gt;&lt;table&gt;&lt;thead&gt;&lt;tr&gt;&lt;th&gt;Feature&lt;/th&gt;&lt;th align=&quot;right&quot;&gt;Original value&lt;/th&gt;&lt;th align=&quot;right&quot;&gt;Mean&lt;/th&gt;&lt;th align=&quot;right&quot;&gt;Standard deviation&lt;/th&gt;&lt;th align=&quot;right&quot;&gt;Scaled value&lt;/th&gt;&lt;/tr&gt;&lt;/thead&gt;&lt;tbody&gt;&lt;tr&gt;&lt;td&gt;Mileage&lt;/td&gt;&lt;td align=&quot;right&quot;&gt;75,000&lt;/td&gt;&lt;td align=&quot;right&quot;&gt;51,000&lt;/td&gt;&lt;td align=&quot;right&quot;&gt;20,000&lt;/td&gt;&lt;td align=&quot;right&quot;&gt;1.2&lt;/td&gt;&lt;/tr&gt;&lt;/tbody&gt;&lt;/table&gt;&lt;h2&gt;Engine alerts&lt;/h2&gt;&lt;p&gt;Suppose:&lt;/p&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;Original value = &lt;code&gt;5&lt;/code&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Mean = &lt;code&gt;2.8&lt;/code&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Standard deviation = &lt;code&gt;2&lt;/code&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;h1&gt;[&lt;br&gt;\frac{5-2.8}{2}&lt;/h1&gt;&lt;h1&gt;\frac{2.2}{2}&lt;/h1&gt;&lt;p&gt;1.1&lt;br&gt;]&lt;/p&gt;&lt;h2&gt;Service gap&lt;/h2&gt;&lt;p&gt;Suppose:&lt;/p&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;Original value = &lt;code&gt;12&lt;/code&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Mean = &lt;code&gt;8&lt;/code&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Standard deviation = &lt;code&gt;5&lt;/code&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;h1&gt;[&lt;br&gt;\frac{12-8}{5}&lt;/h1&gt;&lt;h1&gt;\frac{4}{5}&lt;/h1&gt;&lt;p&gt;0.8&lt;br&gt;]&lt;/p&gt;&lt;h2&gt;Brake wear&lt;/h2&gt;&lt;p&gt;Suppose:&lt;/p&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;Original value = &lt;code&gt;80&lt;/code&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Mean = &lt;code&gt;52&lt;/code&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Standard deviation = &lt;code&gt;20&lt;/code&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;h1&gt;[&lt;br&gt;\frac{80-52}{20}&lt;/h1&gt;&lt;h1&gt;\frac{28}{20}&lt;/h1&gt;&lt;p&gt;1.4&lt;br&gt;]&lt;/p&gt;&lt;h2&gt;Complete calculation&lt;/h2&gt;&lt;table&gt;&lt;thead&gt;&lt;tr&gt;&lt;th&gt;Feature&lt;/th&gt;&lt;th align=&quot;right&quot;&gt;Original value&lt;/th&gt;&lt;th align=&quot;right&quot;&gt;Mean&lt;/th&gt;&lt;th align=&quot;right&quot;&gt;Standard deviation&lt;/th&gt;&lt;th&gt;Calculation&lt;/th&gt;&lt;th align=&quot;right&quot;&gt;Scaled value&lt;/th&gt;&lt;/tr&gt;&lt;/thead&gt;&lt;tbody&gt;&lt;tr&gt;&lt;td&gt;Mileage&lt;/td&gt;&lt;td align=&quot;right&quot;&gt;75,000&lt;/td&gt;&lt;td align=&quot;right&quot;&gt;51,000&lt;/td&gt;&lt;td align=&quot;right&quot;&gt;20,000&lt;/td&gt;&lt;td&gt;&lt;code&gt;(75000 − 51000) / 20000&lt;/code&gt;&lt;/td&gt;&lt;td align=&quot;right&quot;&gt;1.2&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Engine alerts&lt;/td&gt;&lt;td align=&quot;right&quot;&gt;5&lt;/td&gt;&lt;td align=&quot;right&quot;&gt;2.8&lt;/td&gt;&lt;td align=&quot;right&quot;&gt;2&lt;/td&gt;&lt;td&gt;&lt;code&gt;(5 − 2.8) / 2&lt;/code&gt;&lt;/td&gt;&lt;td align=&quot;right&quot;&gt;1.1&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Service gap&lt;/td&gt;&lt;td align=&quot;right&quot;&gt;12&lt;/td&gt;&lt;td align=&quot;right&quot;&gt;8&lt;/td&gt;&lt;td align=&quot;right&quot;&gt;5&lt;/td&gt;&lt;td&gt;&lt;code&gt;(12 − 8) / 5&lt;/code&gt;&lt;/td&gt;&lt;td align=&quot;right&quot;&gt;0.8&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Brake wear&lt;/td&gt;&lt;td align=&quot;right&quot;&gt;80&lt;/td&gt;&lt;td align=&quot;right&quot;&gt;52&lt;/td&gt;&lt;td align=&quot;right&quot;&gt;20&lt;/td&gt;&lt;td&gt;&lt;code&gt;(80 − 52) / 20&lt;/code&gt;&lt;/td&gt;&lt;td align=&quot;right&quot;&gt;1.4&lt;/td&gt;&lt;/tr&gt;&lt;/tbody&gt;&lt;/table&gt;&lt;h2&gt;Meaning of scaled values&lt;/h2&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;&lt;code&gt;0&lt;/code&gt; means the value equals the dataset mean.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;code&gt;1.2&lt;/code&gt; means the value is &lt;code&gt;1.2 standard deviations above&lt;/code&gt; the mean.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;code&gt;-1.2&lt;/code&gt; means the value is &lt;code&gt;1.2 standard deviations below&lt;/code&gt; the mean.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;A positive value means above average.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;A negative value means below average.&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;h2&gt;Python example&lt;/h2&gt;&lt;pre&gt;&lt;code class=&quot;language-python&quot;&gt;import pandas as pd&#xa;from sklearn.preprocessing import StandardScaler&#xa;&#xa;data = pd.DataFrame({&#xa;    &quot;mileage&quot;: [30000, 40000, 50000, 60000, 75000],&#xa;    &quot;engine_alerts&quot;: [1, 2, 2, 4, 5],&#xa;    &quot;service_gap&quot;: [3, 6, 8, 11, 12],&#xa;    &quot;brake_wear&quot;: [25, 40, 50, 65, 80]&#xa;})&#xa;&#xa;scaler = StandardScaler()&#xa;&#xa;scaled_values = scaler.fit_transform(data)&#xa;&#xa;scaled_data = pd.DataFrame(&#xa;    scaled_values,&#xa;    columns=data.columns&#xa;)&#xa;&#xa;print(&quot;Original data:&quot;)&#xa;print(data)&#xa;&#xa;print(&quot;\nMeans:&quot;)&#xa;print(scaler.mean_)&#xa;&#xa;print(&quot;\nStandard deviations:&quot;)&#xa;print(scaler.scale_)&#xa;&#xa;print(&quot;\nScaled data:&quot;)&#xa;print(scaled_data)&#xa;&lt;/code&gt;&lt;/pre&gt;&lt;p&gt;&lt;code&gt;StandardScaler&lt;/code&gt; first calculates the mean and standard deviation from the training records, then applies the formula separately to every value in each feature column.&lt;/p&gt;" vertex="1">
          <mxGeometry height="2500" width="560" x="470" y="7020" as="geometry" />
        </mxCell>
        <UserObject label="&lt;h2 data-section-id=&quot;1folth5&quot; data-start=&quot;428&quot; data-end=&quot;447&quot;&gt;Mileage&lt;/h2&gt;&#xa;&lt;p data-start=&quot;449&quot; data-end=&quot;482&quot;&gt;Suppose the training dataset has:&lt;/p&gt;&#xa;&lt;ul data-start=&quot;484&quot; data-end=&quot;570&quot;&gt;&#xa;&lt;li data-section-id=&quot;1d8f6uc&quot; data-start=&quot;484&quot; data-end=&quot;509&quot;&gt;&#xa;Mean mileage = &lt;code data-start=&quot;501&quot; data-end=&quot;509&quot;&gt;51,000&lt;/code&gt;&#xa;&lt;/li&gt;&#xa;&lt;li data-section-id=&quot;1afwxf&quot; data-start=&quot;510&quot; data-end=&quot;541&quot;&gt;&#xa;Standard deviation = &lt;code data-start=&quot;533&quot; data-end=&quot;541&quot;&gt;20,000&lt;/code&gt;&#xa;&lt;/li&gt;&#xa;&lt;li data-section-id=&quot;1at9nr1&quot; data-start=&quot;542&quot; data-end=&quot;570&quot;&gt;&#xa;Vehicle mileage = &lt;code data-start=&quot;562&quot; data-end=&quot;570&quot;&gt;75,000&lt;/code&gt;&#xa;&lt;/li&gt;&#xa;&lt;/ul&gt;&#xa;&lt;span class=&quot;katex-display&quot;&gt;&lt;span class=&quot;katex&quot;&gt;&lt;span class=&quot;katex-mathml&quot;&gt;&lt;math xmlns=&quot;http://www.w3.org/1998/Math/MathML&quot; display=&quot;block&quot;&gt;&lt;mrow&gt;&lt;mtext&gt;Scaled&amp;nbsp;mileage&lt;/mtext&gt;&lt;mo&gt;=&lt;/mo&gt;&lt;mfrac&gt;&lt;mrow&gt;&lt;mn&gt;75000&lt;/mn&gt;&lt;mo&gt;−&lt;/mo&gt;&lt;mn&gt;51000&lt;/mn&gt;&lt;/mrow&gt;&lt;mn&gt;20000&lt;/mn&gt;&lt;/mfrac&gt;&lt;mo&gt;=&lt;/mo&gt;&lt;mfrac&gt;&lt;mn&gt;24000&lt;/mn&gt;&lt;mn&gt;20000&lt;/mn&gt;&lt;/mfrac&gt;&lt;mo&gt;=&lt;/mo&gt;&lt;mn&gt;1.2&lt;/mn&gt;&lt;/mrow&gt;\text{Scaled mileage}&#xa;=&#xa;\frac{75000-51000}{20000}&#xa;=&#xa;\frac{24000}{20000}&#xa;=&#xa;1.2&lt;/math&gt;&lt;/span&gt;&lt;span class=&quot;katex-html&quot; aria-hidden=&quot;true&quot;&gt;&lt;span class=&quot;base&quot;&gt;&lt;span class=&quot;strut&quot;&gt;&lt;/span&gt;&lt;span class=&quot;mord text&quot;&gt;&lt;span class=&quot;mord&quot;&gt;Scaled&amp;nbsp;mileage&lt;/span&gt;&lt;/span&gt;&lt;span class=&quot;mspace&quot;&gt;&lt;/span&gt;&lt;span class=&quot;mrel&quot;&gt;=&lt;/span&gt;&lt;span class=&quot;mspace&quot;&gt;&lt;/span&gt;&lt;/span&gt;&lt;span class=&quot;base&quot;&gt;&lt;span class=&quot;strut&quot;&gt;&lt;/span&gt;&lt;span class=&quot;mord&quot;&gt;&lt;span class=&quot;mopen nulldelimiter&quot;&gt;&lt;/span&gt;&lt;span class=&quot;mfrac&quot;&gt;&lt;span class=&quot;vlist-t vlist-t2&quot;&gt;&lt;span class=&quot;vlist-r&quot;&gt;&lt;span class=&quot;vlist&quot;&gt;&lt;span&gt;&lt;span class=&quot;pstrut&quot;&gt;&lt;/span&gt;&lt;span class=&quot;mord&quot;&gt;&lt;span class=&quot;mord&quot;&gt;20000&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;span&gt;&lt;span class=&quot;pstrut&quot;&gt;&lt;/span&gt;&lt;span class=&quot;frac-line&quot;&gt;&lt;/span&gt;&lt;/span&gt;&lt;span&gt;&lt;span class=&quot;pstrut&quot;&gt;&lt;/span&gt;&lt;span class=&quot;mord&quot;&gt;&lt;span class=&quot;mord&quot;&gt;75000&lt;/span&gt;&lt;span class=&quot;mspace&quot;&gt;&lt;/span&gt;&lt;span class=&quot;mbin&quot;&gt;−&lt;/span&gt;&lt;span class=&quot;mspace&quot;&gt;&lt;/span&gt;&lt;span class=&quot;mord&quot;&gt;51000&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;span class=&quot;vlist-s&quot;&gt;​&lt;/span&gt;&lt;/span&gt;&lt;span class=&quot;vlist-r&quot;&gt;&lt;span class=&quot;vlist&quot;&gt;&lt;span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;span class=&quot;mclose nulldelimiter&quot;&gt;&lt;/span&gt;&lt;/span&gt;&lt;span class=&quot;mspace&quot;&gt;&lt;/span&gt;&lt;span class=&quot;mrel&quot;&gt;=&lt;/span&gt;&lt;span class=&quot;mspace&quot;&gt;&lt;/span&gt;&lt;/span&gt;&lt;span class=&quot;base&quot;&gt;&lt;span class=&quot;strut&quot;&gt;&lt;/span&gt;&lt;span class=&quot;mord&quot;&gt;&lt;span class=&quot;mopen nulldelimiter&quot;&gt;&lt;/span&gt;&lt;span class=&quot;mfrac&quot;&gt;&lt;span class=&quot;vlist-t vlist-t2&quot;&gt;&lt;span class=&quot;vlist-r&quot;&gt;&lt;span class=&quot;vlist&quot;&gt;&lt;span&gt;&lt;span class=&quot;pstrut&quot;&gt;&lt;/span&gt;&lt;span class=&quot;mord&quot;&gt;&lt;span class=&quot;mord&quot;&gt;20000&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;span&gt;&lt;span class=&quot;pstrut&quot;&gt;&lt;/span&gt;&lt;span class=&quot;frac-line&quot;&gt;&lt;/span&gt;&lt;/span&gt;&lt;span&gt;&lt;span class=&quot;pstrut&quot;&gt;&lt;/span&gt;&lt;span class=&quot;mord&quot;&gt;&lt;span class=&quot;mord&quot;&gt;24000&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;span class=&quot;vlist-s&quot;&gt;​&lt;/span&gt;&lt;/span&gt;&lt;span class=&quot;vlist-r&quot;&gt;&lt;span class=&quot;vlist&quot;&gt;&lt;span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;span class=&quot;mclose nulldelimiter&quot;&gt;&lt;/span&gt;&lt;/span&gt;&lt;span class=&quot;mspace&quot;&gt;&lt;/span&gt;&lt;span class=&quot;mrel&quot;&gt;=&lt;/span&gt;&lt;span class=&quot;mspace&quot;&gt;&lt;/span&gt;&lt;/span&gt;&lt;span class=&quot;base&quot;&gt;&lt;span class=&quot;strut&quot;&gt;&lt;/span&gt;&lt;span class=&quot;mord&quot;&gt;1.2&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&#xa;&lt;p data-start=&quot;657&quot; data-end=&quot;667&quot;&gt;Therefore:&lt;/p&gt;&#xa;&lt;div class=&quot;TyagGW_tableContainer&quot;&gt;&lt;div tabindex=&quot;-1&quot; class=&quot;group TyagGW_tableWrapper flex flex-col-reverse w-fit&quot;&gt;&lt;table data-start=&quot;669&quot; data-end=&quot;811&quot; class=&quot;w-fit min-w-(--thread-content-width)&quot;&gt;&lt;thead data-start=&quot;669&quot; data-end=&quot;740&quot;&gt;&lt;tr data-start=&quot;669&quot; data-end=&quot;740&quot;&gt;&lt;th data-start=&quot;669&quot; data-end=&quot;679&quot; data-col-size=&quot;sm&quot; class=&quot;last:pe-10&quot;&gt;Feature&lt;/th&gt;&lt;th data-start=&quot;679&quot; data-end=&quot;696&quot; data-col-size=&quot;sm&quot; class=&quot;last:pe-10&quot;&gt;Original value&lt;/th&gt;&lt;th data-start=&quot;696&quot; data-end=&quot;703&quot; data-col-size=&quot;sm&quot; class=&quot;last:pe-10&quot;&gt;Mean&lt;/th&gt;&lt;th data-start=&quot;703&quot; data-end=&quot;724&quot; data-col-size=&quot;sm&quot; class=&quot;last:pe-10&quot;&gt;Standard deviation&lt;/th&gt;&lt;th data-start=&quot;724&quot; data-end=&quot;740&quot; data-col-size=&quot;sm&quot; class=&quot;last:pe-10&quot;&gt;Scaled value&lt;/th&gt;&lt;/tr&gt;&lt;/thead&gt;&lt;tbody data-start=&quot;767&quot; data-end=&quot;811&quot;&gt;&lt;tr data-start=&quot;767&quot; data-end=&quot;811&quot;&gt;&lt;td data-start=&quot;767&quot; data-end=&quot;777&quot; data-col-size=&quot;sm&quot;&gt;Mileage&lt;/td&gt;&lt;td data-start=&quot;777&quot; data-end=&quot;786&quot; data-col-size=&quot;sm&quot;&gt;75,000&lt;/td&gt;&lt;td data-col-size=&quot;sm&quot; data-start=&quot;786&quot; data-end=&quot;795&quot;&gt;51,000&lt;/td&gt;&lt;td data-col-size=&quot;sm&quot; data-start=&quot;795&quot; data-end=&quot;804&quot;&gt;20,000&lt;/td&gt;&lt;td data-col-size=&quot;sm&quot; data-start=&quot;804&quot; data-end=&quot;811&quot;&gt;1.2&lt;/td&gt;&lt;/tr&gt;&lt;/tbody&gt;&lt;/table&gt;&lt;/div&gt;&lt;/div&gt;" link="&lt;h2 data-section-id=&quot;1folth5&quot; data-start=&quot;428&quot; data-end=&quot;447&quot;&gt;Mileage&lt;/h2&gt;&#xa;&lt;p data-start=&quot;449&quot; data-end=&quot;482&quot;&gt;Suppose the training dataset has:&lt;/p&gt;&#xa;&lt;ul data-start=&quot;484&quot; data-end=&quot;570&quot;&gt;&#xa;&lt;li data-section-id=&quot;1d8f6uc&quot; data-start=&quot;484&quot; data-end=&quot;509&quot;&gt;&#xa;Mean mileage = &lt;code data-start=&quot;501&quot; data-end=&quot;509&quot;&gt;51,000&lt;/code&gt;&#xa;&lt;/li&gt;&#xa;&lt;li data-section-id=&quot;1afwxf&quot; data-start=&quot;510&quot; data-end=&quot;541&quot;&gt;&#xa;Standard deviation = &lt;code data-start=&quot;533&quot; data-end=&quot;541&quot;&gt;20,000&lt;/code&gt;&#xa;&lt;/li&gt;&#xa;&lt;li data-section-id=&quot;1at9nr1&quot; data-start=&quot;542&quot; data-end=&quot;570&quot;&gt;&#xa;Vehicle mileage = &lt;code dat