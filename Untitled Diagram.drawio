        <mxCell id="GG1ei2N0N4fxY809Vq1g-35" parent="1" style="text;whiteSpace=wrap;" value="Request received      |      vRead Idempotency-Key      |      vGenerate hash of request payload      |      vCheck idempotency table      |      +----------------------+      |                      |      v                      vKey not found            Key found      |                      |      v                      vInsert IN_PROGRESS        Compare request hash      |                      |      v                      |Process business logic      +-----------------------------+      |                      |                             |      v                      v                             vSuccess                 Hash mismatch                Hash same      |                      |                             |      v                      v                             vSave SUCCESS          Return 422                 Check statuswith response                                      |      |                                            |      v                                            |Return response                  +-----------------+------------------+                                 |                 |                  |                                 v                 v                  v                              SUCCESS          IN_PROGRESS          FAILED                                 |                 |                  |                                 v                 v                  v                         Return saved       Return 409 / wait    Retry / return                         response           and retry later      failure" vertex="1">
          <mxGeometry height="200" width="560" x="980" y="3040" as="geometry" />
        </mxCell>
