        <mxCell id="_HcvP6dDgX7jolYNGT8T-4" parent="1" style="text;whiteSpace=wrap;html=1;fontSize=15;" value="&lt;table&gt;&lt;thead&gt;&lt;tr&gt;&lt;th&gt;Component&lt;/th&gt;&lt;th&gt;Meaning&lt;/th&gt;&lt;/tr&gt;&lt;/thead&gt;&lt;tbody&gt;&lt;tr&gt;&lt;td&gt;Cluster&lt;/td&gt;&lt;td&gt;Complete Kubernetes environment&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Node&lt;/td&gt;&lt;td&gt;Machine/VM where containers run&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Pod&lt;/td&gt;&lt;td&gt;Smallest deployable unit in Kubernetes&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Container&lt;/td&gt;&lt;td&gt;Your application runs inside container&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Deployment&lt;/td&gt;&lt;td&gt;Manages replicas and rollout&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Service&lt;/td&gt;&lt;td&gt;Provides stable network access to pods&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Ingress&lt;/td&gt;&lt;td&gt;HTTP/HTTPS routing to services&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;ConfigMap&lt;/td&gt;&lt;td&gt;Stores non-sensitive configuration&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Secret&lt;/td&gt;&lt;td&gt;Stores passwords, keys, tokens&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Volume&lt;/td&gt;&lt;td&gt;Persistent storage&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Namespace&lt;/td&gt;&lt;td&gt;Logical separation inside cluster&lt;/td&gt;&lt;/tr&gt;&lt;/tbody&gt;&lt;/table&gt;" vertex="1">
          <mxGeometry height="260" width="440" x="490" y="150" as="geometry" />
        </mxCell>
        <mxCell id="_HcvP6dDgX7jolYNGT8T-6" parent="1" style="whiteSpace=wrap;html=1;fontSize=16;" value="kubernetes scheduler will check the following things :&amp;nbsp;&lt;span style=&quot;background-color: transparent;&quot;&gt;Which node has free CPU?&lt;/span&gt;&lt;div&gt;Which node has free memory?&lt;/div&gt;&lt;div&gt;Any node selector?&lt;/div&gt;&lt;div&gt;Any taints/tolerations?&lt;/div&gt;&lt;div&gt;Any affinity rule?&lt;/div&gt;" vertex="1">
          <mxGeometry height="150" width="290" x="565" y="580" as="geometry" />
        </mxCell>
        <mxCell id="_HcvP6dDgX7jolYNGT8T-8" parent="1" style="text;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" value="&lt;table&gt;&lt;thead&gt;&lt;tr&gt;&lt;th&gt;Point&lt;/th&gt;&lt;th&gt;Kubernetes&lt;/th&gt;&lt;th&gt;AKS&lt;/th&gt;&lt;/tr&gt;&lt;/thead&gt;&lt;tbody&gt;&lt;tr&gt;&lt;td&gt;Full form&lt;/td&gt;&lt;td&gt;Kubernetes&lt;/td&gt;&lt;td&gt;Azure Kubernetes Service&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;What it is&lt;/td&gt;&lt;td&gt;Open-source container orchestration platform&lt;/td&gt;&lt;td&gt;Managed Kubernetes service from Microsoft Azure&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Ownership&lt;/td&gt;&lt;td&gt;You install and manage it yourself&lt;/td&gt;&lt;td&gt;Azure manages major Kubernetes components for you&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Cloud dependency&lt;/td&gt;&lt;td&gt;Can run anywhere: laptop, VM, data center, AWS, Azure, GCP&lt;/td&gt;&lt;td&gt;Runs on Microsoft Azure&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Control Plane&lt;/td&gt;&lt;td&gt;You manage API Server, Scheduler, Controller Manager, etcd&lt;/td&gt;&lt;td&gt;Azure manages the control plane&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Worker Nodes&lt;/td&gt;&lt;td&gt;You create and manage worker machines&lt;/td&gt;&lt;td&gt;Azure creates VM-based worker nodes in node pools&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Upgrades&lt;/td&gt;&lt;td&gt;You handle Kubernetes upgrades manually&lt;/td&gt;&lt;td&gt;Azure provides managed upgrade options&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Scaling&lt;/td&gt;&lt;td&gt;You configure and manage scaling manually&lt;/td&gt;&lt;td&gt;Supports node pool scaling and cluster autoscaler&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Networking&lt;/td&gt;&lt;td&gt;You configure CNI, load balancer, ingress, DNS yourself&lt;/td&gt;&lt;td&gt;Integrates with Azure VNet, Load Balancer, Application Gateway, Private DNS&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Storage&lt;/td&gt;&lt;td&gt;You manually integrate storage providers&lt;/td&gt;&lt;td&gt;Integrates with Azure Disk, Azure Files, Azure Blob options&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Security&lt;/td&gt;&lt;td&gt;You configure RBAC, secrets, certificates, network policies yourself&lt;/td&gt;&lt;td&gt;Integrates with Microsoft Entra ID, Azure RBAC, Key Vault, Defender for Cloud&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Monitoring&lt;/td&gt;&lt;td&gt;You set up Prometheus, Grafana, logging manually&lt;/td&gt;&lt;td&gt;Integrates with Azure Monitor, Container Insights, Log Analytics&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Best for&lt;/td&gt;&lt;td&gt;Full control, custom infrastructure, on-prem/private cloud&lt;/td&gt;&lt;td&gt;Azure-based production Kubernetes with less operational overhead&lt;/td&gt;&lt;/tr&gt;&lt;/tbody&gt;&lt;/table&gt;" vertex="1">
          <mxGeometry height="470" width="560" x="470" y="870" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
