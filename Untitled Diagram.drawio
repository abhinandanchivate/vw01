        <mxCell id="_rzVe7CSYrXBFZ04XZDb-42" parent="1" style="text;whiteSpace=wrap;" value="Customer complaint        ↓Text normalization        ↓Sentence tokenization        ↓Word tokenization        ↓Special-token extraction        ↓Sentence and word counts        ↓Structured CSV output" vertex="1">
          <mxGeometry height="150" width="560" x="330" y="13230" as="geometry" />
