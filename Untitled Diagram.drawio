t;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span class=&quot;katex-display&quot;&gt;&lt;span class=&quot;katex can-focus&quot; role=&quot;math&quot; tabindex=&quot;0&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span class=&quot;katex-display&quot;&gt;&lt;span class=&quot;katex can-focus&quot; role=&quot;math&quot; tabindex=&quot;0&quot;&gt;f is function ,&amp;nbsp;&lt;/span&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span class=&quot;katex-display&quot;&gt;&lt;span class=&quot;katex can-focus&quot; role=&quot;math&quot; tabindex=&quot;0&quot;&gt;x = input&amp;nbsp;&lt;/span&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span class=&quot;katex-display&quot;&gt;&lt;span class=&quot;katex can-focus&quot; role=&quot;math&quot; tabindex=&quot;0&quot;&gt;f(x) : true relationship between input and output .&lt;/span&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span class=&quot;katex-display&quot;&gt;&lt;span class=&quot;katex can-focus&quot; role=&quot;math&quot; tabindex=&quot;0&quot;&gt;ε : a small quantity, error / noise , tolerance&lt;/span&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span class=&quot;katex-display&quot;&gt;&lt;span class=&quot;katex can-focus&quot; role=&quot;math&quot; tabindex=&quot;0&quot;&gt;y = output / acutal observed value.&lt;/span&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span class=&quot;katex-display&quot;&gt;&lt;span class=&quot;katex can-focus&quot; role=&quot;math&quot; tabindex=&quot;0&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span class=&quot;katex-display&quot;&gt;&lt;span class=&quot;katex can-focus&quot; role=&quot;math&quot; tabindex=&quot;0&quot;&gt;actual output = true pattern + random noise&lt;/span&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span class=&quot;katex-display&quot;&gt;&lt;span class=&quot;katex can-focus&quot; role=&quot;math&quot; tabindex=&quot;0&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span class=&quot;katex-display&quot;&gt;&lt;span cla