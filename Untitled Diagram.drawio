23&lt;/td&gt;&lt;td&gt;Yes&lt;/td&gt;&lt;td&gt;Reject&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;C7&lt;/td&gt;&lt;td align=&quot;right&quot;&gt;₹60,000&lt;/td&gt;&lt;td align=&quot;right&quot;&gt;2 years&lt;/td&gt;&lt;td&gt;Yes&lt;/td&gt;&lt;td align=&quot;right&quot;&gt;45&lt;/td&gt;&lt;td&gt;No&lt;/td&gt;&lt;td&gt;Approve&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;C8&lt;/td&gt;&lt;td align=&quot;right&quot;&gt;₹35,000&lt;/td&gt;&lt;td align=&quot;right&quot;&gt;3 years&lt;/td&gt;&lt;td&gt;Yes&lt;/td&gt;&lt;td align=&quot;right&quot;&gt;31&lt;/td&gt;&lt;td&gt;No&lt;/td&gt;&lt;td&gt;Reject&lt;/td&gt;&lt;/tr&gt;&lt;/tbody&gt;&lt;/table&gt;" vertex="1">
