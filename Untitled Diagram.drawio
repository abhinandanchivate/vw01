        <mxCell id="_rzVe7CSYrXBFZ04XZDb-3" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fontSize=14;" value="Feature Selection" vertex="1">
          <mxGeometry height="220" width="520" x="160" y="3080" as="geometry" />
        </mxCell>
        <mxCell id="_rzVe7CSYrXBFZ04XZDb-7" edge="1" parent="1" source="_rzVe7CSYrXBFZ04XZDb-4" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" target="_rzVe7CSYrXBFZ04XZDb-6" value="">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="_rzVe7CSYrXBFZ04XZDb-4" parent="1" style="whiteSpace=wrap;html=1;fontSize=14;rounded=1;" value="&lt;h2 data-section-id=&quot;sba5oe&quot; data-start=&quot;321&quot; data-end=&quot;350&quot;&gt;What is feature selection?&lt;/h2&gt;&lt;br/&gt;&lt;p data-start=&quot;352&quot; data-end=&quot;486&quot;&gt;Feature selection means choosing only the most useful original input columns and removing irrelevant, duplicate, or low-value columns.&lt;/p&gt;&lt;br/&gt;&lt;p data-start=&quot;488&quot; data-end=&quot;523&quot;&gt;Suppose a vehicle dataset contains:&lt;/p&gt;&lt;br/&gt;&lt;div class=&quot;TyagGW_tableContainer&quot;&gt;&lt;div tabindex=&quot;-1&quot; class=&quot;group TyagGW_tableWrapper flex flex-col-reverse w-fit&quot;&gt;&lt;table data-start=&quot;525&quot; data-end=&quot;774&quot; class=&quot;w-fit min-w-(--thread-content-width)&quot;&gt;&lt;thead data-start=&quot;525&quot; data-end=&quot;549&quot;&gt;&lt;tr data-start=&quot;525&quot; data-end=&quot;549&quot;&gt;&lt;th data-start=&quot;525&quot; data-end=&quot;535&quot; data-col-size=&quot;sm&quot; class=&quot;last:pe-10&quot;&gt;Feature&lt;/th&gt;&lt;th data-start=&quot;535&quot; data-end=&quot;549&quot; data-col-size=&quot;sm&quot; class=&quot;last:pe-10&quot;&gt;Usefulness&lt;/th&gt;&lt;/tr&gt;&lt;/thead&gt;&lt;tbody data-start=&quot;560&quot; data-end=&quot;774&quot;&gt;&lt;tr data-start=&quot;560&quot; data-end=&quot;585&quot;&gt;&lt;td data-start=&quot;560&quot; data-end=&quot;575&quot; data-col-size=&quot;sm&quot;&gt;&lt;code data-start=&quot;562&quot; data-end=&quot;574&quot;&gt;mileage_km&lt;/code&gt;&lt;/td&gt;&lt;td data-col-size=&quot;sm&quot; data-start=&quot;575&quot; data-end=&quot;585&quot;&gt;Useful&lt;/td&gt;&lt;/tr&gt;&lt;tr data-start=&quot;586&quot; data-end=&quot;614&quot;&gt;&lt;td data-start=&quot;586&quot; data-end=&quot;604&quot; data-col-size=&quot;sm&quot;&gt;&lt;code data-start=&quot;588&quot; data-end=&quot;603&quot;&gt;engine_alerts&lt;/code&gt;&lt;/td&gt;&lt;td data-col-size=&quot;sm&quot; data-start=&quot;604&quot; data-end=&quot;614&quot;&gt;Useful&lt;/td&gt;&lt;/tr&gt;&lt;tr data-start=&quot;615&quot; data-end=&quot;648&quot;&gt;&lt;td data-start=&quot;615&quot; data-end=&quot;638&quot; data-col-size=&quot;sm&quot;&gt;&lt;code data-start=&quot;617&quot; data-end=&quot;637&quot;&gt;brake_wear_percent&lt;/code&gt;&lt;/td&gt;&lt;td data-col-size=&quot;sm&quot; data-start=&quot;638&quot; data-end=&quot;648&quot;&gt;Useful&lt;/td&gt;&lt;/tr&gt;&lt;tr data-start=&quot;649&quot; data-end=&quot;689&quot;&gt;&lt;td data-start=&quot;649&quot; data-end=&quot;667&quot; data-col-size=&quot;sm&quot;&gt;&lt;code data-start=&quot;651&quot; data-end=&quot;666&quot;&gt;customer_name&lt;/code&gt;&lt;/td&gt;&lt;td data-col-size=&quot;sm&quot; data-start=&quot;667&quot; data-end=&quot;689&quot;&gt;Usually not useful&lt;/td&gt;&lt;/tr&gt;&lt;tr data-start=&quot;690&quot; data-end=&quot;727&quot;&gt;&lt;td data-start=&quot;690&quot; data-end=&quot;705&quot; data-col-size=&quot;sm&quot;&gt;&lt;code data-start=&quot;692&quot; data-end=&quot;704&quot;&gt;vehicle_id&lt;/code&gt;&lt;/td&gt;&lt;td data-start=&quot;705&quot; data-end=&quot;727&quot; data-col-size=&quot;sm&quot;&gt;Usually not useful&lt;/td&gt;&lt;/tr&gt;&lt;tr data-start=&quot;728&quot; data-end=&quot;774&quot;&gt;&lt;td data-start=&quot;728&quot; data-end=&quot;752&quot; data-col-size=&quot;sm&quot;&gt;&lt;code data-start=&quot;730&quot; data-end=&quot;751&quot;&gt;registration_number&lt;/code&gt;&lt;/td&gt;&lt;td data-col-size=&quot;sm&quot; data-start=&quot;752&quot; data-end=&quot;774&quot;&gt;Usually not useful&lt;/td&gt;&lt;/tr&gt;&lt;/tbody&gt;&lt;/table&gt;&lt;/div&gt;&lt;/div&gt;&lt;br/&gt;&lt;p data-start=&quot;776&quot; data-end=&quot;812&quot;&gt;&lt;/p&gt;" vertex="1">
          <mxGeometry height="550" width="590" x="360" y="3460" as="geometry" />
        </mxCell>
        <mxCell id="_rzVe7CSYrXBFZ04XZDb-9" edge="1" parent="1" source="_rzVe7CSYrXBFZ04XZDb-6" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" target="_rzVe7CSYrXBFZ04XZDb-8" value="">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="_rzVe7CSYrXBFZ04XZDb-6" parent="1" style="whiteSpace=wrap;html=1;fontSize=14;rounded=1;" value="&lt;h2 data-section-id=&quot;1jzsvuz&quot; data-start=&quot;906&quot; data-end=&quot;935&quot;&gt;Why use feature selection?&lt;/h2&gt;&lt;br/&gt;&lt;ul data-start=&quot;937&quot; data-end=&quot;1136&quot;&gt;&lt;br/&gt;&lt;li data-section-id=&quot;1kwgrsp&quot; data-start=&quot;937&quot; data-end=&quot;964&quot;&gt;&lt;br/&gt;Reduces unnecessary data.&lt;br/&gt;&lt;/li&gt;&lt;br/&gt;&lt;li data-section-id=&quot;vbtun4&quot; data-start=&quot;965&quot; data-end=&quot;989&quot;&gt;&lt;br/&gt;Makes training faster.&lt;br/&gt;&lt;/li&gt;&lt;br/&gt;&lt;li data-section-id=&quot;oo76fo&quot; data-start=&quot;990&quot; data-end=&quot;1012&quot;&gt;&lt;br/&gt;Reduces overfitting.&lt;br/&gt;&lt;/li&gt;&lt;br/&gt;&lt;li data-section-id=&quot;1ubn2t1&quot; data-start=&quot;1013&quot; data-end=&quot;1047&quot;&gt;&lt;br/&gt;Improves model interpretability.&lt;br/&gt;&lt;/li&gt;&lt;br/&gt;&lt;li data-section-id=&quot;3goavx&quot; data-start=&quot;1048&quot; data-end=&quot;1085&quot;&gt;&lt;br/&gt;Can improve prediction performance.&lt;br/&gt;&lt;/li&gt;&lt;br/&gt;&lt;li data-section-id=&quot;1r0r3qs&quot; data-start=&quot;1086&quot; data-end=&quot;1136&quot;&gt;&lt;br/&gt;Removes highly correlated or duplicate features.&lt;/li&gt;&lt;/ul&gt;" vertex="1">
          <mxGeometry height="605" width="535" x="390" y="4190" as="geometry" />
        </mxCell>
        <mxCell id="_rzVe7CSYrXBFZ04XZDb-8" parent="1" style="whiteSpace=wrap;html=1;fontSize=14;rounded=1;" value="&lt;h2 data-section-id=&quot;19e2sm0&quot; data-start=&quot;1138&quot; data-end=&quot;1174&quot;&gt;Main feature-selection techniques&lt;/h2&gt;&lt;br/&gt;&lt;div class=&quot;TyagGW_tableContainer&quot;&gt;&lt;div tabindex=&quot;-1&quot; class=&quot;group TyagGW_tableWrapper flex flex-col-reverse w-fit&quot;&gt;&lt;table data-start=&quot;1176&quot; data-end=&quot;1505&quot; class=&quot;w-fit min-w-(--thread-content-width)&quot;&gt;&lt;thead data-start=&quot;1176&quot; data-end=&quot;1215&quot;&gt;&lt;tr data-start=&quot;1176&quot; data-end=&quot;1215&quot;&gt;&lt;th data-start=&quot;1176&quot; data-end=&quot;1188&quot; data-col-size=&quot;sm&quot; class=&quot;last:pe-10&quot;&gt;Technique&lt;/th&gt;&lt;th data-start=&quot;1188&quot; data-end=&quot;1203&quot; data-col-size=&quot;sm&quot; class=&quot;last:pe-10&quot;&gt;How it works&lt;/th&gt;&lt;th data-start=&quot;1203&quot; data-end=&quot;1215&quot; data-col-size=&quot;sm&quot; class=&quot;last:pe-10&quot;&gt;Examples&lt;/th&gt;&lt;/tr&gt;&lt;/thead&gt;&lt;tbody data-start=&quot;1230&quot; data-end=&quot;1505&quot;&gt;&lt;tr data-start=&quot;1230&quot; data-end=&quot;1316&quot;&gt;&lt;td data-start=&quot;1230&quot; data-end=&quot;1246&quot; data-col-size=&quot;sm&quot;&gt;Filter method&lt;/td&gt;&lt;td data-col-size=&quot;sm&quot; data-start=&quot;1246&quot; data-end=&quot;1282&quot;&gt;Selects features using statistics&lt;/td&gt;&lt;td data-col-size=&quot;sm&quot; data-start=&quot;1282&quot; data-end=&quot;1316&quot;&gt;Correlation, chi-square, ANOVA&lt;/td&gt;&lt;/tr&gt;&lt;tr data-start=&quot;1317&quot; data-end=&quot;1406&quot;&gt;&lt;td data-start=&quot;1317&quot; data-end=&quot;1334&quot; data-col-size=&quot;sm&quot;&gt;Wrapper method&lt;/td&gt;&lt;td data-col-size=&quot;sm&quot; data-start=&quot;1334&quot; data-end=&quot;1373&quot;&gt;Tries different feature combinations&lt;/td&gt;&lt;td data-col-size=&quot;sm&quot; data-start=&quot;1373&quot; data-end=&quot;1406&quot;&gt;Recursive Feature Elimination&lt;/td&gt;&lt;/tr&gt;&lt;tr data-start=&quot;1407&quot; data-end=&quot;1505&quot;&gt;&lt;td data-start=&quot;1407&quot; data-end=&quot;1425&quot; data-col-size=&quot;sm&quot;&gt;Embedded method&lt;/td&gt;&lt;td data-col-size=&quot;sm&quot; data-start=&quot;1425&quot; data-end=&quot;1466&quot;&gt;Model selects features during training&lt;/td&gt;&lt;td data-col-size=&quot;sm&quot; data-start=&quot;1466&quot; data-end=&quot;1505&quot;&gt;Lasso, Decision Tree, Random Forest&lt;/td&gt;&lt;/tr&gt;&lt;/tbody&gt;&lt;/table&gt;&lt;/div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="302.5" width="402.5" x="456.25" y="5010" as="geometry" />
        </mxCell>
        <mxCell id="_rzVe7CSYrXBFZ04XZDb-10" parent="1" style="text;whiteSpace=wrap;html=1;" value="&lt;table&gt;&lt;thead&gt;&lt;tr&gt;&lt;th&gt;Category&lt;/th&gt;&lt;th&gt;Technique&lt;/th&gt;&lt;th&gt;How it works&lt;/th&gt;&lt;th&gt;Best suited for&lt;/th&gt;&lt;/tr&gt;&lt;/thead&gt;&lt;tbody&gt;&lt;tr&gt;&lt;td&gt;Filter&lt;/td&gt;&lt;td&gt;Pearson Correlation&lt;/td&gt;&lt;td&gt;Measures the linear relationship between a numerical feature and a numerical target. Features with stronger correlation are selected.&lt;/td&gt;&lt;td&gt;Regression&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Filter&lt;/td&gt;&lt;td&gt;Spearman Correlation&lt;/td&gt;&lt;td&gt;Measures monotonic relationships using ranked values. Useful when relationships are not strictly linear.&lt;/td&gt;&lt;td&gt;Regression, ordinal data&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Filter&lt;/td&gt;&lt;td&gt;Chi-Square Test&lt;/td&gt;&lt;td&gt;Checks whether a categorical feature is statistically associated with a categorical target.&lt;/td&gt;&lt;td&gt;Classification&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Filter&lt;/td&gt;&lt;td&gt;ANOVA F-Test&lt;/td&gt;&lt;td&gt;Compares the mean values of a numerical feature across different target classes.&lt;/td&gt;&lt;td&gt;Classification&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Filter&lt;/td&gt;&lt;td&gt;Mutual Information&lt;/td&gt;&lt;td&gt;Measures how much information a feature provides about the target, including nonlinear relationships.&lt;/td&gt;&lt;td&gt;Classification and regression&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Filter&lt;/td&gt;&lt;td&gt;Variance Threshold&lt;/td&gt;&lt;td&gt;Removes features whose values rarely change across records.&lt;/td&gt;&lt;td&gt;Removing constant or nearly constant columns&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Filter&lt;/td&gt;&lt;td&gt;Information Gain&lt;/td&gt;&lt;td&gt;Measures the reduction in uncertainty about the target after using a feature.&lt;/td&gt;&lt;td&gt;Decision-tree classification&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Wrapper&lt;/td&gt;&lt;td&gt;Recursive Feature Elimination&lt;/td&gt;&lt;td&gt;Trains a model, removes the least important feature, retrains the model, and repeats the process.&lt;/td&gt;&lt;td&gt;Small and medium datasets&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Wrapper&lt;/td&gt;&lt;td&gt;Recursive Feature Elimination with Cross-Validation&lt;/td&gt;&lt;td&gt;Performs RFE while using cross-validation to determine the best number of features.&lt;/td&gt;&lt;td&gt;More reliable feature selection&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Wrapper&lt;/td&gt;&lt;td&gt;Forward Feature Selection&lt;/td&gt;&lt;td&gt;Starts with no features and adds the feature that improves model performance the most at each step.&lt;/td&gt;&lt;td&gt;When few features are expected to be useful&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Wrapper&lt;/td&gt;&lt;td&gt;Backward Feature Elimination&lt;/td&gt;&lt;td&gt;Starts with all features and removes the least useful feature at each step.&lt;/td&gt;&lt;td&gt;When the initial feature count is manageable&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Wrapper&lt;/td&gt;&lt;td&gt;Exhaustive Feature Selection&lt;/td&gt;&lt;td&gt;Evaluates every possible feature combination and selects the best-performing subset.&lt;/td&gt;&lt;td&gt;Very small numbers of features&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Wrapper&lt;/td&gt;&lt;td&gt;Sequential Feature Selection&lt;/td&gt;&lt;td&gt;Adds or removes features sequentially according to model performance.&lt;/td&gt;&lt;td&gt;Classification and regression&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Embedded&lt;/td&gt;&lt;td&gt;Lasso Regression&lt;/td&gt;&lt;td&gt;Applies L1 regularization, shrinking some feature coefficients exactly to zero. Zero-coefficient features are removed.&lt;/td&gt;&lt;td&gt;Regression and linear classification&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Embedded&lt;/td&gt;&lt;td&gt;Elastic Net&lt;/td&gt;&lt;td&gt;Combines L1 and L2 regularization. It selects features while handling highly correlated variables better than pure Lasso.&lt;/td&gt;&lt;td&gt;Regression with correlated features&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Embedded&lt;/td&gt;&lt;td&gt;Decision Tree Feature Importance&lt;/td&gt;&lt;td&gt;Selects features according to how much they reduce impurity when splitting tree nodes.&lt;/td&gt;&lt;td&gt;Classification and regression&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Embedded&lt;/td&gt;&lt;td&gt;Random Forest Feature Importance&lt;/td&gt;&lt;td&gt;Combines feature importance scores from many decision trees.&lt;/td&gt;&lt;td&gt;Nonlinear datasets&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Embedded&lt;/td&gt;&lt;td&gt;Gradient Boosting Feature Importance&lt;/td&gt;&lt;td&gt;Measures how frequently and effectively features are used across sequentially trained trees.&lt;/td&gt;&lt;td&gt;Complex classification and regression&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Embedded&lt;/td&gt;&lt;td&gt;XGBoost Feature Importance&lt;/td&gt;&lt;td&gt;Ranks features using measures such as gain, weight, and coverage.&lt;/td&gt;&lt;td&gt;Large structured datasets&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Embedded&lt;/td&gt;&lt;td&gt;Logistic Regression with L1 Regularization&lt;/td&gt;&lt;td&gt;Shrinks unimportant feature coefficients to zero during classification-model training.&lt;/td&gt;&lt;td&gt;Binary and multiclass classification&lt;/td&gt;&lt;/tr&gt;&lt;/tbody&gt;&lt;/table&gt;" vertex="1">
          <mxGeometry height="960" width="820" x="260" y="5500" as="geometry" />
        </mxCell>
        <mxCell id="_rzVe7CSYrXBFZ04XZDb-11" parent="1" style="text;whiteSpace=wrap;fontSize=23;" value="All features &#xa; ↓&#xa;Statistical test &#xa; ↓&#xa;Selected features &#xa; ↓&#xa;Model training" vertex="1">
          <mxGeometry height="210" width="400" x="240" y="6770" as="geometry" />
        </mxCell>
        <mxCell id="_rzVe7CSYrXBFZ04XZDb-12" parent="1" style="text;whiteSpace=wrap;fontSize=17;" value="Input data &#xa; ↓&#xa;Missing-value handling&#xa; ↓&#xa;One-hot encoding&#xa; ↓&#xa;Scaling &#xa; ↓&#xa;PCA &#xa; ↓&#xa;Classification model" vertex="1">
          <mxGeometry height="260" width="600" x="210" y="6420" as="geometry" />
        </mxCell>
